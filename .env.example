# --- PostgreSQL ---
POSTGRES_USER=lexora
POSTGRES_PASSWORD=change_me
POSTGRES_DB=lexora
# From host machine (ports published by Docker Compose):
DATABASE_URL=postgresql://lexora:change_me@localhost:5432/lexora

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Ollama (Compose service name on the Docker network: http://ollama:11434) ---
OLLAMA_HOST=http://localhost:11434

# --- API (Express) ---
# API_PORT=4000

# --- Firebase Admin (API + worker) ---
# FIREBASE_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=./path-to-service-account.json
